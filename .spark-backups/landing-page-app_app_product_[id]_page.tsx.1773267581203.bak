export async function generateStaticParams() {
  return [{ id: "1" }, { id: "2" }, { id: "3" }];
}

export default async function ProductPage({ params }: { params: Promise<{ id: string }> }) {
  const { id } = await params;
  const imageUrl = `https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=1920&h=1080&fit=crop&q=85&auto=format`;
  return (
    <main className="min-h-screen bg-white p-4 flex flex-col items-center">
      <h1 className="text-3xl font-bold mb-6">Product {id}</h1>
      <div className="max-w-2xl w-full bg-gray-50 rounded-lg shadow-md overflow-hidden">
        <img
          src={imageUrl}
          alt={`Product ${id}`}
          className="object-cover w-full h-64"
        />
        <div className="p-6">
          <h2 className="text-2xl font-semibold mb-2">Elegant Watch {id}</h2>
          <p className="text-gray-700 mb-4">
            Detailed description for product {id}. Premium watch with timeless design.
          </p>
          <p className="text-xl font-bold mb-4">$199.99</p>
          <button className="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition">
            Add to Cart
          </button>
        </div>
      </div>
      <a href="/" className="mt-6 text-blue-600 hover:underline">
        ← Back to Home
      </a>
    </main>
  );
}
